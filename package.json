{
  "name": "relay-ai-learning-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Relay desktop app for learning AI with a plan-and-execute agent.",
  "type": "module",
  "scripts": {
    "start": "node scripts/dev.mjs",
    "dev:all": "node scripts/dev.mjs",
    "dev:server": "agent-server/.venv/bin/uvicorn relay.server:app --reload --host 127.0.0.1 --port 8000",
    "dev": "vite --host 127.0.0.1",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -w -p tsconfig.electron.json\" \"wait-on http://127.0.0.1:5173 dist-electron/main.js && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.electron.json && tsc && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.3"
  }
}
