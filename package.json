{
  "name": "study-ai-electron-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "agent-server/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --config agent-web/vite.config.js --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "start": "concurrently -k \"vite --config agent-web/vite.config.js --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build --config agent-web/vite.config.js",
    "preview": "vite preview --config agent-web/vite.config.js --host 127.0.0.1",
    "electron": "electron ."
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.5.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
