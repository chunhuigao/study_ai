    "preview": "vite preview --host 127.0.0.1",
    "electron": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.5",
    "typescript": "^5.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "electron": "^33.2.1",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {}
}
